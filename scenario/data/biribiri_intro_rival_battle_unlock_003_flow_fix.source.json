        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "flustered",
          "position": "center",
          "text": "な、なによその謎の語呂合わせ！ ちょっと悔しいじゃない！"
        },
        {
          "speaker": "霧島 真冬",
          "character_id": "bb",
          "face": "analysis",
          "position": "right",
          "text": "店名を用いた即興反論。論理性は低いですが、場の空気を維持する効果はあります。"
        },
        {
          "speaker": "日向 なつ",
          "character_id": "bc",
          "face": "smile",
          "position": "left",
          "text": "あちし、ちんまりもこだわりも、どっちもかわいいと思うけどな～。"
        },
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "angry",
          "text": "なつ！ そこで丸くしない！"
        }
      ]
    },
