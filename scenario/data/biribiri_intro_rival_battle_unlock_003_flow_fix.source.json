        {
          "speaker": "霧島 真冬",
          "character_id": "bb",
          "face": "analysis",
          "position": "right",
          "text": "店長が店頭に立つ小規模運営。人件費圧縮、接客密度向上……しかし、それだけでは説明不能。"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "text": "まあ、色々あってな。"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "monologue": true,
          "text": "（実は家電星人たちのおかげなんだけどな。さすがに初対面で説明する話でもない。）"
        }
      ]
    },
    {
      "scene_id": "scene_006_hidamari_pushback",
      "background": "store_floor",
      "bgm": "comedy_tension",
      "lines": [
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "provoking",
          "position": "center",
          "text": "ふーん。でも納得いかないわね。こんな、ひだまりっていうか、ちんまりストアのくせに。"
