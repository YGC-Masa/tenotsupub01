  "scenes": [
    {
      "scene_id": "scene_001_storefront_unusual_manager",
      "background": "store_front",
      "bgm": "daily_store",
      "lines": [
        {
          "speaker": "ナレーション",
          "text": "その日、ひだまりストアの店頭には、珍しく店長が立っていた。"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "text": "今日は店頭の様子も見ておくか。家電星人たちが来てから、客層も少し変わってきたしな。"
        },
        {
          "cmd": "play_sfx",
          "name": "door_chime"
        },
        {
          "speaker": "？？？",
          "text": "カランコロン♪"
        },
        {
          "speaker": "ナレーション",
          "text": "来店チャイムとともに、赤黒い制服の三人組が店内へ入ってきた。"
        },
        {
          "speaker": "星野 緋奈",
          "character_id": "aa",
          "face": "normal",
          "position": "left",
          "text": "ね、店長。あの三人……明らかに競合他社の子っぽくない？"
        },
        {
          "speaker": "小麦沢 こがね",
          "character_id": "ad",
          "face": "thinking",
          "position": "right",
          "text": "ん～、あれ、最近できたおっきい店の子たちかなー？ 赤黒の制服、めっちゃ目立つし。"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "text": "堂々と敵情視察とはな……うちの恐ろしさを思い知るがよい……。"
        },
        {
          "speaker": "草壁 翠",
          "character_id": "ac",
          "face": "tsukkomi",
          "position": "center",
          "text": "はいはい、店長。仕事してください。"
        }
      ]
    },
    {
      "scene_id": "scene_002_biribiri_enters",
      "background": "store_floor",
      "bgm": "rival_sneak",
      "lines": [
        {
          "cmd": "play_sfx",
          "name": "footsteps"
        },
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "smirk",
          "position": "center",
          "text": "へぇ、意外と狭いのね。"
        },
        {
          "speaker": "霧島 真冬",
