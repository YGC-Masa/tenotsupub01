        {
          "cmd": "play_sfx",
          "name": "impact"
        },
        {
          "speaker": "星野 緋奈",
          "character_id": "aa",
          "face": "angry",
          "position": "left",
          "text": "なにおー！ うちはちんまりじゃなくて、あったかいお店なんだからね！"
