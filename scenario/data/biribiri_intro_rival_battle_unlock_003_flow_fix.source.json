      "background": "store_floor_rival",
      "bgm": "rival_sneak",
      "lines": [
        {
          "cmd": "play_sfx",
          "name": "item_pick"
        },
        {
          "speaker": "霧島 真冬",
          "character_id": "bb",
          "face": "thinking",
          "position": "right",
          "text": "棚数、導線、展示密度……いずれも大型店には及ばない。にもかかわらず、最近の評判は異常に高い。"
        },
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "serious",
          "position": "center",
          "text": "そう。それが納得いかないのよ。こんな、ひだまりっていうか……。"
        },
        {
          "speaker": "日向 なつ",
          "character_id": "bc",
          "face": "smile",
          "position": "left",
          "text": "ぽかぽかストア？"
        },
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "grin",
          "text": "ちんまりストア。"
        },
        {
          "speaker": "日向 なつ",
