        {
          "speaker": "小麦沢 こがね",
          "character_id": "ad",
          "face": "angry",
          "position": "right",
          "text": "そうだし！ てか、ちんまりって言い方かわいくない？ いや、でも失礼だし！"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "text": "うちは、ひだまりストアのこだわりストアだ。おまえらこそ、おだまりストアだ！"
