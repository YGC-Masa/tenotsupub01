      "background": "store_floor",
      "bgm": "comedy_tension",
      "lines": [
        {
          "speaker": "天神 小春",
          "character_id": "ba",
          "face": "smirk",
          "position": "center",
          "text": "で、あんた。責任者呼んできて。話が早い人がいいわ。"
        },
        {
          "speaker": "店長",
          "character_id": "player",
          "text": "一応、俺が店長なんだけど。"
