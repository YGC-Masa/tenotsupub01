        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "知ってるわけじゃない。\nそう見える気がしただけだ。"
    },
    {
      "speaker": "夜空",
      "text": "見てないのに。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
