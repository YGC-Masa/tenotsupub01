          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "だから見たい。"
    },
    {
      "speaker": "夜空",
      "text": "……本当にしつこい。",
