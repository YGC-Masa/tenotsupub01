        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……合ってる。\nでも、ここの記入だけ一段ずれてる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
