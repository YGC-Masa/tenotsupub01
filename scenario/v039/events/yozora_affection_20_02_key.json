          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空もそう思うんだな。"
    },
    {
      "speaker": "夜空",
