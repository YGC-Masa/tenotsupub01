          "id": "ah",
          "src": "images/assets/char/h11401.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……本当でも、言わなくていいことはある。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i11101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h11401.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "照れてるのか？",
