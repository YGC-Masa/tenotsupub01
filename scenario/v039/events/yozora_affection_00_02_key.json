          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h11401.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空、ちょっと耳赤いかも。",
