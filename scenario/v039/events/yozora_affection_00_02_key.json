  "steps": [
    {
      "speaker": "",
      "text": "――ひだまりストア・店内売り場――",
      "bg": "images/assets/bg/battle_store_lv1.png",
      "bgMode": "forceReplace",
      "forceBackgroundReplace": true,
      "clearStorySprites": true
    },
    {
      "speaker": "美空",
      "text": "えっと……この加湿器は、冬場の乾燥対策におすすめで……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "客",
      "text": "リビングで使いたいんだけど、どのくらいの広さまで大丈夫なの？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "あ、はい。えっと、こちらの商品は……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10801.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "木造なら八畳。プレハブなら十三畳くらい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10801.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "あ、そうです！\n木造なら八畳、プレハブなら十三畳くらいまで対応できます！",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "客",
      "text": "なるほど。じゃあ、寝室でもリビングでも使えそうだね。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "はい。あと、給水タンクも大きめなので、こまめに水を入れなくても大丈夫です。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "フィルター交換の目安も言った方がいい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "あっ、そうだね。\nフィルター交換の目安は、だいたいワンシーズンに一回くらいです。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "客",
      "text": "助かるよ。じゃあ、これにしようかな。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ありがとうございます！",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "客がレジへ向かっていく。\n美空はほっとしたように息をついた。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ふぅ……夜空、ありがとう。助かったよ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "別に。横から見てただけ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "でも、夜空が言ってくれなかったら、ちょっと詰まっちゃってたかも。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "美空ならすぐ思い出してた。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "そうかな？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "そう。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空、ナイスフォローだったな。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i11101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "今の、かなり自然だった。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i11101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "ぼくは接客してない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、美空を助けただろ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
