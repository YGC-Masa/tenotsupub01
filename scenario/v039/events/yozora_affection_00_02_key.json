          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10201.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……そういう言い方、しなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
