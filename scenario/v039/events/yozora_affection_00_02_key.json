        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺は、夜空みたいなフォローも必要だと思う。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10301.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i11101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "わたしもそう思うよ。\n夜空が横にいてくれると、安心するもん。",
