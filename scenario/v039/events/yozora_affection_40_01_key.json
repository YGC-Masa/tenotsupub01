          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺は夜空と話したいんだけどな。"
    },
    {
      "speaker": "夜空",
      "text": "……そういうの、いい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "この前の武道イベントのこと、少し気になって。"
    },
    {
      "speaker": "夜空",
      "text": "気にしなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "気にするなって言われても。"
    },
    {
      "speaker": "夜空",
      "text": "じゃあ忘れて。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "忘れた方がいいのか？"
    },
    {
      "speaker": "夜空",
      "text": "忘れて。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に？"
    },
    {
      "speaker": "夜空",
      "text": "本当に。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
