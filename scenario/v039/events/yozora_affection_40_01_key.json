    {
      "speaker": "夜空",
      "text": "そういうところも、ずるい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "またずるいか。"
    },
    {
      "speaker": "夜空",
      "text": "うん。\nだから、美空のところに行けば。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空は、俺と話したくないのか？"
    },
    {
      "speaker": "夜空",
      "text": "今は。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
