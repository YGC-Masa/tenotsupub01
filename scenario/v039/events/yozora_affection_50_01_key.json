          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "謝らないで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空、少し休む？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "休まない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ココア、作ろうか？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "いらない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "今、美空に優しくされたら、もっと嫌なことを考えそう。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――美空の表情が、少しだけ揺れた。\n夜空はそれに気づいて、すぐに目を伏せる。"
    },
    {
      "speaker": "夜空",
      "text": "……ごめん。\n今の、違う。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "違う？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "違う。\n美空が嫌なんじゃない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "美空は悪くない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "そればっかり言ってる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "言わないで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "まだ何も言ってない。"
    },
    {
      "speaker": "夜空",
      "text": "言いそうだった。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "……そうか。"
    },
    {
      "speaker": "夜空",
      "text": "店長は、すぐそういう顔をする。\n大丈夫かって。\n無理するなって。\n話していいって。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "してるかもしれない。"
    },
    {
      "speaker": "夜空",
      "text": "そういうところ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "嫌か？"
    },
    {
      "speaker": "夜空",
      "text": "嫌。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そっか。"
    },
    {
      "speaker": "夜空",
      "text": "でも、嫌じゃないのも嫌。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "だから、見ないで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――夜空はカバンを手に取った。\n閉店後にすぐ帰る時の動きではない。\nどこかへ逃げるための、少し急いだ動きだった。"
    },
    {
      "speaker": "店長",
      "text": "どこか行くのか？"
    },
    {
      "speaker": "夜空",
      "text": "少し歩くだけ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "今から？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "暗いよ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "知ってる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "一人で大丈夫？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "大丈夫。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "その大丈夫は信用していいやつか？"
    },
    {
      "speaker": "夜空",
      "text": "今日は、信用しなくていい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "なら、送る。"
    },
    {
      "speaker": "夜空",
      "text": "来ないで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "少し一人にして。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――その言葉は静かだった。\nけれど、店内の空気を一段冷たくするには十分だった。"
    },
    {
      "speaker": "美空",
      "text": "夜空、どこに行くの？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "言わない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "駅の方？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "駅は人が多い。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、運動公園の方か？"
    },
    {
      "speaker": "夜空",
      "text": "……なんで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "前に、夜になるとあの辺りは静かだって言ってたから。"
    },
    {
      "speaker": "夜空",
      "text": "覚えてなくていい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "覚えてる。"
    },
    {
      "speaker": "夜空",
      "text": "そういうところ。\n本当に、そういうところが嫌。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "謝らなくていい。\n……謝られると、もっと行きたくなる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "行きたくなる？"
    },
    {
      "speaker": "夜空",
      "text": "ここから。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――夜空は店の奥を見る。\n美空のいる場所。\n店長のいる場所。\n明るくて、温かくて、逃げ場がない場所。"
    },
    {
      "speaker": "夜空",
      "text": "美空のところに行けばいい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "え？"
    },
    {
      "speaker": "夜空",
      "text": "店長は、美空のところに行けばいい。\n美空を見てればいい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "美空は明るい。\n美空は優しい。\n美空はちゃんと笑える。\n店長が心配するなら、美空の方を見てればいい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空、そういう話じゃない。"
    },
    {
      "speaker": "夜空",
      "text": "そういう話だよ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "違う。"
    },
    {
      "speaker": "夜空",
      "text": "違わない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_coat_muffler_main50.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
