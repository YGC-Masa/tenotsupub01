    {
      "speaker": "夜空",
      "text": "美空。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "星空観察会、きれいそうですよね。\n前にお客様が話していて、少し気になってたんです。",
