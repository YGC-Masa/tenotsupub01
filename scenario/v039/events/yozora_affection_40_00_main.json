      "text": "夜空も、次だよね。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_budo_gi_main40.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_budo_gi_main40.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……うん。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_budo_gi_main40.png",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/yozora_budo_gi_main40.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空の演武も楽しみにしてる。"
    },
    {
      "speaker": "夜空",
      "text": "楽しみにしなくていい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/misora_budo_gi_main40.png",
          "opacity": 1
