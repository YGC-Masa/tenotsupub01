          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "連絡もしなかった。\n勝手に出ていった。\n帰るのも遅くなった。",
