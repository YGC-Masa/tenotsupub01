    {
      "speaker": "夜空",
      "text": "たぶん、まだ甘い。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そうだな。"
    },
    {
      "speaker": "夜空",
      "text": "言わなくていい。",
