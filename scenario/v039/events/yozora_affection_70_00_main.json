      ]
    },
    {
      "speaker": "店長",
      "text": "そうか？"
    },
    {
      "speaker": "夜空",
      "text": "そう。\n近づきたいけど、見られたくない。\n気づいてほしいけど、言われたくない。\n忘れてほしいけど、忘れないでほしい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "……本当に、面倒。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空らしい。"
    },
    {
      "speaker": "夜空",
      "text": "言わなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
