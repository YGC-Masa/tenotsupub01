          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "でも、今のは……忘れないで。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "忘れない。"
    },
    {
      "speaker": "夜空",
      "text": "即答しないで。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。\nでも、忘れない。"
    },
    {
      "speaker": "夜空",
      "text": "……ずるい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――夜空はそう言って、ほんの少しだけ笑った。\n照れくさそうで、困ったようで、それでも、取り消すことはしなかった。",
      "showEventCg": true,
      "eventCg": "images/assets/cg/cg_yozora_main70_winter_park_05.png",
      "cgFit": "cover",
      "cgAlign": "center center"
    },
    {
      "speaker": "夜空",
      "text": "……ありがとうとは、まだ言わない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/yozora_coat_main50.png",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
