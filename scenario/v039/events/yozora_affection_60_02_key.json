        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "本当に？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に。"
    },
    {
      "speaker": "夜空",
      "text": "……信用できない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空、すごく心配してるね。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "だから、心配じゃない。\n責任。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
