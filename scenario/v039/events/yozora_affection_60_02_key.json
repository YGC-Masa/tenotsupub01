          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "義務か。"
    },
    {
      "speaker": "夜空",
      "text": "そう。\n責任と義務。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空らしい言い方。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "言わなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        },
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――夜空はマグカップを置く。\n表情は真剣だった。\n真剣すぎて、少しだけ方向を間違えているようにも見えた。"
    },
    {
      "speaker": "夜空",
      "text": "もし、店長に何かあったら。",
      "storySprites": [
