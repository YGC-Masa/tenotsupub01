    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。\nこれも余計か。"
    },
    {
      "speaker": "夜空",
      "text": "余計。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そっか。"
    },
    {
      "speaker": "夜空",
      "text": "でも……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "放っておいてほしい時に、そう言われると困る。",
