        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "困るのか。"
    },
    {
      "speaker": "夜空",
      "text": "うん。\n本当に放っておいてほしいのか、わからなくなる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空自身も？"
    },
    {
      "speaker": "夜空",
      "text": "……言わない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "そこで引くの、ほんとにずるい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "何度目だろうな。"
    },
    {
      "speaker": "夜空",
      "text": "数えなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "text": "――信号が赤になり、夜空は足を止める。",
      "speaker": ""
    },
    {
      "text": "店長も少し横に並ぶ。\n夜空はすぐに半歩分だけ距離を取った。"
    },
    {
      "speaker": "店長",
      "text": "距離、取ったな。"
    },
    {
      "speaker": "夜空",
      "text": "近かったから。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "……別に、近いのが嫌っていうより。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "今は、近いと困る。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "どうして？"
    },
    {
      "speaker": "夜空",
      "text": "……聞かないで。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "また引く。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "聞かないでって言ったから。"
    },
    {
      "speaker": "夜空",
      "text": "そうだけど。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "なに。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺は、夜空を責めに来たわけじゃない。"
    },
    {
      "speaker": "夜空",
      "text": "わかってる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "この前のことを、無理に聞き出すつもりもない。"
    },
    {
      "speaker": "夜空",
      "text": "わかってる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、どうして避ける？"
    },
    {
      "speaker": "夜空",
      "text": "わかってるから。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "……。"
    },
    {
      "speaker": "夜空",
      "text": "店長が責めないのも、無理に聞かないのも、わかってる。\n美空が心配してくれるのも、わかってる。\n二人とも悪くないって、わかってる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "だから、困る。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "怒れないから？"
    },
    {
      "speaker": "夜空",
      "text": "そう。\n怒れたら楽なのに。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺が悪いってことにできたら？"
    },
    {
      "speaker": "夜空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それでもいいぞ。"
    },
    {
      "speaker": "夜空",
      "text": "よくない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "店長が悪いってことにしたら、たぶん楽。\nでも、それは違うってわかってる。\nだから、もっと嫌になる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "自分が？"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "そういうところ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "すぐ見つける。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "見つけるつもりじゃなかった。"
    },
    {
      "speaker": "夜空",
      "text": "見つけてる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "……。"
    },
    {
      "speaker": "夜空",
      "text": "美空のことを羨ましいって、少し思った。\n美空が褒められるのは嬉しいのに、苦しいって思った。\nそれを店長に見られた。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "それが、嫌。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺に見られたことが？"
    },
    {
      "speaker": "夜空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空じゃなくて？"
    },
    {
      "speaker": "夜空",
      "text": "美空に見られるのも嫌。\nでも、店長に見られるのは……もっと変。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "変？"
    },
    {
      "speaker": "夜空",
      "text": "美空なら、優しくしてくれる。\nたぶん、全部受け止めようとしてくれる。\nそれはそれで苦しいけど、想像できる。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "俺は？"
    },
    {
      "speaker": "夜空",
      "text": "店長は、わからない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わからない？"
    },
    {
      "speaker": "夜空",
      "text": "責めない。\n笑わない。\nでも、見てる。\n逃げようとすると、追ってくる。\n放っておいてって言うと、放っておかない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それは、迷惑か？"
    },
    {
      "speaker": "夜空",
      "text": "……迷惑なら、もっと楽だった。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "迷惑じゃないから困ってるの。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "text": "――信号が青に変わる。",
      "speaker": ""
    },
    {
      "text": "けれど夜空はすぐに歩き出さなかった。\n店長も黙って待つ。"
    },
    {
      "speaker": "夜空",
      "text": "……行かないの？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空が歩くのを待ってる。"
    },
    {
      "speaker": "夜空",
      "text": "待たなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、待つ。"
    },
    {
      "speaker": "夜空",
      "text": "本当にずるい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そうかもしれない。"
    },
    {
      "speaker": "夜空",
      "text": "……認めるの、禁止。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "絶対わかってない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "text": "――夜空は小さく息を吐き、再び歩き出す。",
      "speaker": ""
    },
    {
      "text": "今度は、さっきより少しだけゆっくりだった。"
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "なに。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "今日は、無理に聞かない。"
    },
    {
      "speaker": "夜空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、避けられてるのは少し寂しい。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それだけは言っておく。"
    },
    {
      "speaker": "夜空",
      "text": "……そういうこと、言わなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "ごめん。"
    },
    {
      "speaker": "夜空",
      "text": "謝らなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "……寂しいの？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "少しな。"
    },
    {
      "speaker": "夜空",
      "text": "美空のところに行けば、寂しくないでしょ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空といる時間と、夜空といる時間は違う。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空の代わりに夜空を見てるわけじゃないし、夜空の代わりに美空を見てるわけでもない。"
    },
    {
      "speaker": "夜空",
      "text": "……そういうの。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "余計だったか？"
    },
    {
      "speaker": "夜空",
      "text": "余計。\nでも……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "今のは、少しだけ覚えておく。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "言わなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "……本当に？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に。"
    },
    {
      "speaker": "夜空",
      "text": "今日は信用してない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "今日は？"
    },
    {
      "speaker": "夜空",
      "text": "今日は。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、いつかは信用される可能性もあるのか。"
    },
    {
      "speaker": "夜空",
      "text": "拾わないで。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "……でも、完全にないとは言ってない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それも拾っていいか？"
    },
    {
      "speaker": "夜空",
      "text": "だめ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "本当に？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に。"
    },
    {
      "speaker": "夜空",
      "text": "……変な店長。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "text": "――駅裏の静かな通りに入ると、人通りは少し減った。",
      "speaker": ""
    },
    {
      "text": "夜空は店長から視線を外したまま、歩き続ける。"
    },
    {
      "speaker": "店長",
      "text": "夜空、ここから一人で大丈夫か？"
    },
    {
      "speaker": "夜空",
      "text": "大丈夫。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "その大丈夫は信用していいやつか？"
    },
    {
      "speaker": "夜空",
      "text": "……美空みたいなこと言わないで。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空なら聞くと思って。"
    },
    {
      "speaker": "夜空",
      "text": "聞く。\n絶対聞く。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、俺も聞く。"
    },
    {
      "speaker": "夜空",
      "text": "真似しなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、心配だから。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "このまま送るか？"
    },
    {
      "speaker": "夜空",
      "text": "送らなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に？"
    },
    {
      "speaker": "夜空",
      "text": "本当に。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、ここまでにする。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空？"
    },
    {
      "speaker": "夜空",
      "text": "追ってこないの？",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "追ってほしくないんじゃなかったか？"
    },
    {
      "speaker": "夜空",
      "text": "……そう。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "なら、今日はここでやめておく。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、困ったら連絡してくれ。"
    },
    {
      "speaker": "夜空",
      "text": "しない。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それでもいい。\n一応言っただけだ。"
    },
    {
      "speaker": "夜空",
      "text": "一応が多い。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そうかもな。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "text": "――夜空は少しだけ歩き出して、すぐに立ち止まった。",
      "speaker": ""
    },
    {
      "text": "振り返りはしない。\nただ、背中越しに小さく声を落とす。"
    },
    {
      "speaker": "夜空",
      "text": "店長。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "ん？"
    },
    {
      "speaker": "夜空",
      "text": "今日は……ついてこなくていい。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかった。"
    },
    {
      "speaker": "夜空",
      "text": "でも。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "……本当に、全部放っておかれたら、それはそれで腹が立つ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "難しいな。"
    },
    {
      "speaker": "夜空",
      "text": "人間ってそういうものでしょ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
