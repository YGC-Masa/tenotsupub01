      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "それが、避けてるように見える。"
    },
    {
      "speaker": "夜空",
      "text": "見えるだけ。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "本当に？"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
