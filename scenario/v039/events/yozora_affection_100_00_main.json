        },
        {
          "id": "ai",
          "src": "images/assets/char/i10901.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "またどこか見つけたの。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10901.webp",
          "opacity": 1
        }
      ]
    },
    {
