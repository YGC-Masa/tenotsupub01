  "steps": [
    {
      "speaker": "",
      "text": "――ひだまりストア・休憩室――",
      "bg": "images/assets/bgev/bg_office_hidamari.png",
      "bgMode": "forceReplace",
      "forceBackgroundReplace": true,
      "clearStorySprites": true
    },
    {
      "speaker": "",
      "text": "――昼休憩のひだまりストア。"
    },
    {
      "speaker": "",
      "text": "休憩室には、やわらかな春の日差しが差し込んでいた。"
    },
    {
      "speaker": "",
      "text": "テーブルの上には、白いマグカップと黒いマグカップ。"
    },
    {
      "speaker": "",
      "text": "その隣に、店長用の湯飲みが置かれている。"
    },
    {
      "speaker": "",
      "text": "――いつもの休憩室。"
    },
    {
      "speaker": "",
      "text": "いつもの香り。"
    },
    {
      "speaker": "",
      "text": "いつもの距離。"
    },
    {
      "speaker": "",
      "text": "けれど、今日は少しだけ違っていた。"
    },
    {
      "speaker": "",
      "text": "美空が、楽しそうにスマホを見ている。"
    },
    {
      "speaker": "美空",
      "text": "夜空。\nここ、行ってみない？",
