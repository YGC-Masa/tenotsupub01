          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "考えないよりいい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "うん。\nそれも夜空らしい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "美空までそれ言う。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "わたしが言うのもだめ？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……だめじゃないけど。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "美空が言うならいいのか？"
    },
    {
      "speaker": "夜空",
      "text": "店長が言うと、なんか変。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "変か。"
    },
    {
      "speaker": "夜空",
      "text": "うん。\n店長は、変なところまで見ようとするから。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そんなつもりはないんだけどな。"
    },
    {
      "speaker": "夜空",
      "text": "つもりがなくても見てる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "じゃあ、気をつける。"
    },
    {
      "speaker": "夜空",
      "text": "たぶん無理。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "信用ないな。"
    },
    {
      "speaker": "夜空",
      "text": "ない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空、でも店長のことは少し信用してるよね？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "してない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "即答。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "信用してたら、もっと困る。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "どうして？"
    },
    {
      "speaker": "夜空",
      "text": "……知らない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そっか。"
    },
    {
      "speaker": "夜空",
      "text": "そこで引くの、やっぱりずるい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "これもずるいのか。"
    },
    {
      "speaker": "夜空",
      "text": "うん。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――美空は展示棚の白いリボンを整える。\n夜空はそれを見て、隣の黒い小物飾りを少しだけ位置調整した。"
    },
    {
      "speaker": "店長",
      "text": "白と黒、並べると綺麗だな。"
    },
    {
      "speaker": "美空",
      "text": "本当ですね。\n明るい白と、落ち着いた黒。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "わかりやすい対比。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "でも、どっちかが上ってわけじゃない。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "白だけだと少し眩しいし、黒だけだと少し重い。\n両方あるから、ちょうどいい感じがする。"
    },
    {
      "speaker": "夜空",
      "text": "店長、売り場の話してる？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "半分くらいは。"
    },
    {
      "speaker": "夜空",
      "text": "残り半分は？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "夜空たちの話。"
    },
    {
      "speaker": "夜空",
      "text": "……そういうの、やめて。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "悪い。"
    },
    {
      "speaker": "夜空",
      "text": "でも……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "売り場の話としてなら、少しだけわかる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "白だけだと、目立ちすぎる時がある。\n黒があると、締まる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "でも、黒だけだと、重くなる。\n白があると、明るくなる。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "夜空……それって。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "売り場の話。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "そっか。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "そう。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "いい組み合わせだな。"
    },
    {
      "speaker": "夜空",
      "text": "……売り場としてはね。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "売り場としては。"
    },
    {
      "speaker": "夜空",
      "text": "繰り返さなくていい。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "",
      "text": "――夜空はそう言いながら、黒いリボンの端を指で整えた。\nその仕草は丁寧で、少しだけ大事そうにも見えた。"
    },
    {
      "speaker": "店長",
      "text": "夜空。"
    },
    {
      "speaker": "夜空",
      "text": "なに。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "黒を選んだ理由が、美空の反対だったとしてもさ。"
    },
    {
      "speaker": "夜空",
      "text": "……。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "今、それを似合うようにしてるのは夜空だと思う。"
    },
    {
      "speaker": "夜空",
      "text": "……そういうの。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "余計だったか？"
    },
    {
      "speaker": "夜空",
      "text": "余計。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "ごめん。"
    },
    {
      "speaker": "夜空",
      "text": "……でも。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "うん。"
    },
    {
      "speaker": "夜空",
      "text": "少しだけ、考えておく。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "そっか。"
    },
    {
      "speaker": "夜空",
      "text": "変な意味じゃない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "わかってる。"
    },
    {
      "speaker": "夜空",
      "text": "絶対わかってない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "店長",
      "text": "努力する。"
    },
    {
      "speaker": "夜空",
      "text": "努力でどうにかなるの、それ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ふふっ。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "美空まで笑わないで。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ごめん。\nでも、今日の夜空、少し楽しそうだったから。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "してない。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "うん。\nそういうことにしておくね。",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "夜空",
      "text": "……それ、店長の真似？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
        {
          "id": "ai",
          "src": "images/assets/char/i10101.webp",
          "opacity": 1
        }
      ]
    },
    {
      "speaker": "美空",
      "text": "ばれた？",
      "storySprites": [
        {
          "id": "ah",
          "src": "images/assets/char/h10202.webp",
          "opacity": 1
        },
